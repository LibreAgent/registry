# Copy to .env for `docker compose`. docker-compose composes DATABASE_URL from these.
POSTGRES_USER=libreagents
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=libreagents
POSTGRES_PORT=5432
APP_PORT=3000

# For running migrate/seed or the app OUTSIDE docker (point at your Postgres):
# DATABASE_URL=postgres://libreagents:change-me-in-production@localhost:5432/libreagents
# REGISTRY_ROOT=..
